# CricPulseIQ Environment Variables Template
# Copy this to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Firebase Client (Frontend / Expo) ─────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=cricpulseiq.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=cricpulseiq
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=cricpulseiq.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ── Genkit Backend URL ────────────────────────────────────────────────────────
# Local development:
EXPO_PUBLIC_GENKIT_URL=http://localhost:4000
# Production (Cloud Run or Firebase Functions):
# EXPO_PUBLIC_GENKIT_URL=https://your-cloud-run-url.run.app

# ── Vertex AI / GCP Backend ──────────────────────────────────────────────────
GCP_PROJECT_ID=cricpulseiq
GCP_LOCATION=us-central1
